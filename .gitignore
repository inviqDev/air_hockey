# Unity project .gitignore

#
# Keep the project source of truth under version control:
# - Assets/ and all corresponding .meta files
# - Packages/
# - ProjectSettings/
# - .gitignore
# - README.md
#

# Ignore generated caches, local tools, IDE state,
# build output, diagnostics, and machine-specific files.

# ----------------------------------------------------------------------

# Local project documentation and configuration

# ----------------------------------------------------------------------

/AGENTS.md
/Docs/AI/

/.editorconfig

# ----------------------------------------------------------------------

# Unity-generated cache and local state

# ----------------------------------------------------------------------

/.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Unity diagnostics and captures

/[Mm]emoryCaptures/
/[Rr]ecordings/
/[Cc]rashes/

*.log
sysinfo.txt
mono_crash.*

# ----------------------------------------------------------------------

# Unity-generated scene, test, and dependency cache

# ----------------------------------------------------------------------

/[Aa]ssets/[Ss]ceneDependencyCache*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
InitTestScene*.unity*

# ----------------------------------------------------------------------

# Rider and Unity-generated IDE files

# ----------------------------------------------------------------------

# Rider / IntelliJ local project state

/.idea/

# Rider solution and personal settings

*.DotSettings
*.DotSettings.user

# Unity-generated solution and project files

*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Generated debug-symbol metadata

*.pidb.meta
*.pdb.meta
*.mdb.meta

# Legacy auto-generated Rider Unity plugin

/[Aa]ssets/Plugins/Editor/JetBrains*

# Gradle project cache

/.gradle/

# ----------------------------------------------------------------------

# Build output and exported players

# ----------------------------------------------------------------------

/[Bb]uild/
/[Bb]uilds/
/ExportedObj/

*.apk
*.aab
*.app
*.symbols.zip
*.unitypackage
*.unitypackage.meta

# ----------------------------------------------------------------------

# Addressables-generated content

# ----------------------------------------------------------------------

/ServerData/
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# ----------------------------------------------------------------------

# Visual Scripting-generated files

# ----------------------------------------------------------------------

/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# ----------------------------------------------------------------------

# External tools and generated files

# ----------------------------------------------------------------------

# Blender temporary backup files

*.blend1
*.blend1.meta

# Crashlytics-generated configuration

crashlytics-build.properties

# Unity Asset Store tools

/[Aa]ssets/AssetStoreTools*

# ----------------------------------------------------------------------

# Operating-system files

# ----------------------------------------------------------------------

.DS_Store
Thumbs.db
Desktop.ini
