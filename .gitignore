# Unity project .gitignore
#
# Commit the source of truth:
# - Assets/
# - Packages/
# - ProjectSettings/
#
# Do not commit generated caches, local IDE state, build output, or machine-specific files.

# Unity cache and local machine state
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
*.log
sysinfo.txt
mono_crash.*

# Unity generated scene/test cache
/[Aa]ssets/[Ss]ceneDependencyCache*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
InitTestScene*.unity*

# Unity generated IDE/project files
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated debug symbol metadata
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Build output and exported players
/[Bb]uild/
/[Bb]uilds/
/ExportedObj/
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta

# Addressables generated data
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting generated files
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Blender temporary imports
*.blend1
*.blend1.meta

# Crashlytics
crashlytics-build.properties

# Rider / IntelliJ local state
.idea/
*.DotSettings.user
*.csproj.DotSettings
*.sln.DotSettings

# Visual Studio / VS Code / local editor state
.vs/
.vscode/

# JetBrains Rider Unity plugin auto-generated folder
/[Aa]ssets/Plugins/Editor/JetBrains*

# Consulo / Fleet / Gradle
.consulo/
.fleet/
.gradle/

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Local-only notes and planning
/FutureIdeas/
/Docs/
/AGENTS.md

# Optional Unity Asset Store tools
# /[Aa]ssets/AssetStoreTools*
